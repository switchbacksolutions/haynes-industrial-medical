---
/**
 * Footer.astro — Haynes Industrial Medicine
 */

const year = new Date().getFullYear();

const SERVICES = [
  { href: '/services#dot-drug-testing', label: 'DOT Drug Testing' },
  { href: '/services#respirator-fit', label: 'Respirator Fit Testing' },
  { href: '/services#cpr-aed', label: 'CPR/AED Training' },
];

const COMPANY = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-brand-900 text-brand-200">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand block -->
      <div class="lg:col-span-2">
        <p class="text-xl font-bold text-white">
          Haynes<br />
          <span class="text-accent-400">Industrial Medicine</span>
        </p>
        <p class="mt-4 text-sm leading-relaxed text-brand-300 max-w-xs">
          Occupational health built by people who understand industrial work.
          Fast, expert care — because your team doesn't have time to waste.
        </p>
        <div class="mt-6 space-y-1 text-sm">
          <p class="text-white font-medium">
            <a href="tel:+15555550100" class="no-underline text-accent-400 hover:text-accent-300 transition-colors">
              (555) 555-0100
            </a>
          </p>
          <p class="text-brand-300">Mon – Fri 7 am – 6 pm · Sat 8 am – 2 pm</p>
        </div>
      </div>

      <!-- Services -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-400 mb-4">Services</p>
        <ul class="space-y-2 list-none m-0 p-0">
          {SERVICES.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-brand-300 no-underline hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-400 mb-4">Company</p>
        <ul class="space-y-2 list-none m-0 p-0">
          {COMPANY.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-brand-300 no-underline hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
        <a
          href="/contact"
          class="mt-6 inline-flex items-center gap-2 rounded-md bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600 transition-colors no-underline"
        >
          Schedule an Appointment
        </a>
      </div>
    </div>

    <div class="mt-12 border-t border-brand-800 pt-8 text-center text-xs text-brand-500">
      <p>&copy; {year} Haynes Industrial Medicine. All rights reserved.</p>
      <p class="mt-1">
        Built by <a href="https://switchbacksolutions.net" class="text-brand-400 hover:text-white transition-colors no-underline" target="_blank" rel="noopener noreferrer">Switchback Solutions</a>
      </p>
    </div>
  </div>
</footer>
