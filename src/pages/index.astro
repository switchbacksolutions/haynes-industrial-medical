---
/**
 * src/pages/index.astro — Haynes Industrial Medicine Homepage
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Haynes Industrial Medicine"
  description="DOT drug testing, respirator fit testing, and CPR/AED training for industrial workforces. Fast, straightforward, built for people who know industrial work."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden bg-brand-900">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=1920&q=80"
        alt="Industrial worker in a hard hat at a manufacturing facility"
        class="h-full w-full object-cover object-center opacity-40"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Gradient overlay — stronger on left so text pops -->
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900/95 via-brand-900/70 to-brand-900/30"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-28 sm:px-6">
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <span class="inline-flex items-center gap-2 rounded-full border border-accent-500/40 bg-accent-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-accent-400">
          DOT Testing · Respirator Fit · CPR/AED
        </span>

        <!-- Headline -->
        <h1 class="mt-6 text-5xl font-bold leading-tight tracking-tight text-white sm:text-6xl text-balance">
          Keep Your Workforce<br />
          <span class="text-accent-400">Compliant and Certified</span>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-xl leading-relaxed text-brand-200 max-w-xl text-pretty">
          DOT drug testing, respirator fit testing, and CPR/AED certification —
          delivered fast by people who understand what industrial work actually demands.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary text-base px-7 py-3">
            Schedule Testing or Training
          </a>
          <a href="/services" class="btn-ghost text-base px-7 py-3">
            See Our Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       STATS STRIP
  ════════════════════════════════════════════════════════════════ -->
  <section class="bg-accent-500">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ul class="grid grid-cols-2 divide-x divide-accent-400/40 lg:grid-cols-4 list-none m-0 p-0">
        {[
          { stat: 'Same-Day', label: 'Testing Available' },
          { stat: '24 hrs', label: 'Results Turnaround' },
          { stat: 'On-Site', label: 'Services Available' },
          { stat: '15+ yrs', label: 'Industrial Experience' },
        ].map(({ stat, label }) => (
          <li class="flex flex-col items-center py-6 px-4 text-center">
            <span class="text-2xl font-bold text-white">{stat}</span>
            <span class="mt-1 text-sm font-medium text-accent-100">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SERVICES
  ════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-xs font-semibold uppercase tracking-widest text-accent-600">What We Do</span>
        <h2 class="mt-3 text-4xl font-bold text-brand-900 text-balance">
          Testing and Training Built for Industry
        </h2>
        <p class="mt-4 text-lg text-gray-600">
          We focus on what industrial employers need most — keeping workers compliant, certified, and ready to work.
        </p>
      </div>

      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
        {[
          {
            title: 'DOT Drug Testing',
            desc: 'DOT-compliant urine drug screens for regulated employers. Pre-employment, random, post-accident, and reasonable suspicion — with fast turnaround and MRO review.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
            href: '/services#dot-drug-testing',
          },
          {
            title: 'Respirator Fit Testing',
            desc: 'OSHA-required quantitative and qualitative fit testing for tight-fitting respirators. We test, document, and get your workers cleared to work.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" /></svg>`,
            href: '/services#respirator-fit',
          },
          {
            title: 'CPR/AED Training',
            desc: 'American Heart Association-aligned CPR and AED certification for individuals and teams. We come to your facility and work around your schedule.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>`,
            href: '/services#cpr-aed',
          },
        ].map(({ title, desc, icon, href }) => (
          <li>
            <a href={href} class="group flex flex-col h-full rounded-xl border border-gray-100 bg-white p-7 shadow-sm hover:shadow-md hover:border-accent-200 transition-all no-underline">
              <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700 group-hover:bg-accent-50 group-hover:text-accent-600 transition-colors" set:html={icon} />
              <h3 class="mt-5 text-lg font-semibold text-brand-900 group-hover:text-accent-600 transition-colors">{title}</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed flex-1">{desc}</p>
              <span class="mt-4 text-xs font-semibold text-accent-600 group-hover:underline">Learn more →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       DIFFERENTIATORS
  ════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-xs font-semibold uppercase tracking-widest text-accent-600">Why Choose Us</span>
        <h2 class="mt-3 text-4xl font-bold text-brand-900 text-balance">
          We See Your Workers the Way You Do
        </h2>
      </div>

      <div class="grid gap-10 lg:grid-cols-2">

        <!-- Differentiator 1: Industrial Experience -->
        <div class="relative overflow-hidden rounded-2xl bg-brand-900 text-white">
          <img
            src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=900&q=80"
            alt="Industrial worker operating heavy equipment"
            class="absolute inset-0 h-full w-full object-cover object-center opacity-25"
            loading="lazy"
          />
          <div class="relative p-10">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/20 text-accent-400">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
              </svg>
            </span>
            <h3 class="mt-6 text-2xl font-bold leading-snug text-balance">
              We've Worked the Floor.<br />
              <span class="text-accent-400">We Know What's at Stake.</span>
            </h3>
            <p class="mt-4 text-brand-200 leading-relaxed">
              The Haynes family has run industrial operations for over fifteen years. We've managed crews,
              dealt with OSHA audits, and watched what happens when occupational health is treated as an afterthought.
              That experience is built into everything we do.
            </p>
            <ul class="mt-6 space-y-3 text-sm text-brand-200">
              {[
                'We understand production pressure — and work around it',
                'We speak the language of your safety program',
                'We know which regulations actually matter for your industry',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Differentiator 2: Speed & Respect -->
        <div class="relative overflow-hidden rounded-2xl bg-brand-900 text-white">
          <img
            src="https://images.unsplash.com/photo-1565098772267-60af42b81ef2?auto=format&fit=crop&w=900&q=80"
            alt="Workers collaborating at an industrial facility"
            class="absolute inset-0 h-full w-full object-cover object-center opacity-25"
            loading="lazy"
          />
          <div class="relative p-10">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/20 text-accent-400">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </span>
            <h3 class="mt-6 text-2xl font-bold leading-snug text-balance">
              Your Time Isn't Billable<br />
              <span class="text-accent-400">When You're in a Waiting Room.</span>
            </h3>
            <p class="mt-4 text-brand-200 leading-relaxed">
              An hour waiting at a clinic is an hour your worker isn't earning. We've engineered
              our entire operation around speed — because respecting your team means respecting their time.
            </p>
            <ul class="mt-6 space-y-3 text-sm text-brand-200">
              {[
                'Same-day appointments, usually within the hour',
                'Digital paperwork completed before arrival',
                'Results sent directly to your safety manager',
                'On-site services that come to your facility',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <span class="text-xs font-semibold uppercase tracking-widest text-accent-600">Simple Process</span>
      <h2 class="mt-3 text-4xl font-bold text-brand-900">Getting Started Is Simple</h2>
      <p class="mt-4 text-lg text-gray-600">
        Schedule testing or training in minutes. Here's how it works.
      </p>

      <ol class="mt-14 grid gap-8 sm:grid-cols-3 list-none m-0 p-0 text-left">
        {[
          {
            step: '01',
            title: 'Call or Book Online',
            desc: 'Tell us what you need — DOT drug screens, respirator fit testing, or CPR/AED training. Same-day testing is almost always available.',
          },
          {
            step: '02',
            title: 'We Handle It Fast',
            desc: 'Workers come to us or we come to your facility. No unnecessary steps — just the test or certification your compliance program requires.',
          },
          {
            step: '03',
            title: 'Documentation Delivered Same Day',
            desc: 'Drug screen results, fit test records, and training certificates go straight to your safety team — ready for your files.',
          },
        ].map(({ step, title, desc }) => (
          <li class="relative pl-0">
            <span class="text-6xl font-black text-brand-50 leading-none select-none">{step}</span>
            <h3 class="mt-2 text-xl font-bold text-brand-900">{title}</h3>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">{desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       INDUSTRIES SERVED
  ════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-center text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10">
        Industries We Serve
      </p>
      <ul class="flex flex-wrap justify-center gap-3 list-none m-0 p-0">
        {[
          'Manufacturing', 'Transportation & Logistics', 'Construction',
          'Oil & Gas', 'Mining', 'Utilities', 'Warehousing',
          'Chemical Processing', 'Shipbuilding', 'Heavy Equipment',
        ].map((industry) => (
          <li class="rounded-full border border-brand-200 bg-white px-5 py-2 text-sm font-medium text-brand-700 shadow-sm">
            {industry}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CTA BANNER
  ════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-brand-900 py-24">
    <!-- Subtle texture -->
    <div class="absolute inset-0 opacity-10"
         style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 12px 12px;"></div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h2 class="text-4xl font-bold text-white text-balance">
        Ready to Schedule Testing or Training?
      </h2>
      <p class="mt-5 text-lg text-brand-200 max-w-xl mx-auto text-pretty">
        Tell us what your operation needs. We'll get your workers tested,
        certified, and back on the job — fast.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-primary text-base px-8 py-3.5">
          Schedule Testing or Training
        </a>
        <a href="tel:+15555550100" class="btn-ghost text-base px-8 py-3.5">
          Call (555) 555-0100
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
