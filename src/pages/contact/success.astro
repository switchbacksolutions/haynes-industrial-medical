---
/**
 * src/pages/contact/success.astro — Post-form-submission confirmation
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Message Sent — Haynes Industrial Medicine"
  description="Your message has been received. We'll be in touch shortly."
>
  <main class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <div class="rounded-xl border border-green-200 bg-green-50 p-8 text-center dark:border-green-800 dark:bg-green-950">
      <svg class="mx-auto h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
      </svg>
      <h1 class="mt-4 text-2xl font-semibold text-green-800 dark:text-green-200">Message Sent</h1>
      <p class="mt-2 text-green-700 dark:text-green-300">
        Thanks for reaching out. We'll be in touch shortly.
      </p>
      <a href="/contact" class="mt-6 btn-primary inline-flex">Send Another Message</a>
    </div>
  </main>
</BaseLayout>
